// ============================================================
// KalaSetu — Firebase Storage Security Rules
// ============================================================
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check file size
    function isUnderMaxSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }

    // Helper: Check if file is an image
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Helper: Check if file is a document
    function isDocument() {
      return request.resource.contentType.matches('application/pdf')
        || request.resource.contentType.matches('image/(jpeg|png)');
    }

    // App Check — append && hasAppCheck() when ENFORCE phase is active
    function hasAppCheck() {
      return request.app != null;
    }

    // Firestore cross-reference helpers
    function artworkArtistId(artworkId) {
      return firestore.get(/databases/(default)/documents/artworks/$(artworkId)).data.artistId;
    }

    function eventOrganizerId(eventId) {
      return firestore.get(/databases/(default)/documents/events/$(eventId)).data.organizerId;
    }

    function isChatParticipant(roomId) {
      return request.auth.uid in
        firestore.get(/databases/(default)/documents/chatRooms/$(roomId)).data.participants;
    }

    // ── Artwork Images ────────────────────────────────────
    // Path: artworks/{userId}/{artworkId}/{fileName}
    match /artworks/{userId}/{artworkId}/{fileName} {
      allow read: if true;

      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && isUnderMaxSize(10);

      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && isUnderMaxSize(10);

      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // Legacy path: artworks/{artworkId}/{fileName}
    match /artworks/{artworkId}/{fileName} {
      allow read: if true;

      allow create: if isAuthenticated()
        && firestore.exists(/databases/(default)/documents/artworks/$(artworkId))
        && request.auth.uid == artworkArtistId(artworkId)
        && isImage()
        && isUnderMaxSize(10);

      allow update: if isAuthenticated()
        && firestore.exists(/databases/(default)/documents/artworks/$(artworkId))
        && request.auth.uid == artworkArtistId(artworkId)
        && isImage()
        && isUnderMaxSize(10);

      allow delete: if isAuthenticated()
        && firestore.exists(/databases/(default)/documents/artworks/$(artworkId))
        && request.auth.uid == artworkArtistId(artworkId);
    }

    // ── User Avatars & Profile Images ─────────────────────
    // Path: users/{userId}/{fileName}
    match /users/{userId}/{fileName} {
      // Anyone can read user avatars
      allow read: if true;

      // Only the user can upload their own avatar
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && isUnderMaxSize(5);

      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && isUnderMaxSize(5);

      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ── Verification Documents ────────────────────────────
    // Path: verifications/{userId}/{fileName}
    match /verifications/{userId}/{fileName} {
      // Only the applicant and admins can read
      allow read: if isAuthenticated()
        && (request.auth.uid == userId
            || request.auth.token.admin == true);

      // Only the applicant can upload
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isDocument()
        && isUnderMaxSize(5);

      allow update: if false;
      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ── Post Media ────────────────────────────────────────
    // Path: posts/{userId}/{fileName}
    match /posts/{userId}/{fileName} {
      allow read: if true;

      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && isUnderMaxSize(10);

      allow delete: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ── Chat Media ────────────────────────────────────────
    // Path: chats/{roomId}/{fileName}
    match /chats/{roomId}/{fileName} {
      allow read: if isAuthenticated()
        && isChatParticipant(roomId);

      allow create: if isAuthenticated()
        && isChatParticipant(roomId)
        && isImage()
        && isUnderMaxSize(10);

      allow delete: if false;
    }

    // ── Event Images ──────────────────────────────────────
    // Path: events/{eventId}/{fileName}
    match /events/{eventId}/{fileName} {
      allow read: if true;

      allow create: if isAuthenticated()
        && request.auth.uid == eventOrganizerId(eventId)
        && isImage()
        && isUnderMaxSize(10);

      allow update: if isAuthenticated()
        && request.auth.uid == eventOrganizerId(eventId)
        && isImage()
        && isUnderMaxSize(10);

      allow delete: if isAuthenticated()
        && request.auth.uid == eventOrganizerId(eventId);
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
