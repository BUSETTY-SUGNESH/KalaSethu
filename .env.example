# ============================================================
# KalaSetu — Environment Variables
# ============================================================
# Local: copy to `.env.local`
# Production: set in Vercel Project Settings → Environment Variables
# Never commit `.env.local` or any file containing real secrets.

# --- Firebase Client (browser-safe; NEXT_PUBLIC_ prefix required) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# reCAPTCHA v3 site key for Firebase App Check (production)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# App Check debug token — localhost only; register in Firebase Console
# NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# --- Firebase Admin SDK (server-only; Vercel API routes) ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste full private key; use literal \n for line breaks in Vercel
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Razorpay (checkout uses public key; secrets stay in Cloud Functions) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Session and middleware (server-only) ---
# Generate: openssl rand -base64 32
AUTH_SESSION_SECRET=
MIDDLEWARE_SECRET=

# --- App URL (production: https://your-app.vercel.app) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
