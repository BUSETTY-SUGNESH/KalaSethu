// ============================================================
// KalaSetu — Firestore Security Rules
// Role-based access control for all collections
// ============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isModerator() {
      return isAuthenticated() && (getUserRole() == 'moderator' || getUserRole() == 'admin');
    }

    function isArtist() {
      return isAuthenticated() && getUserRole() in ['artist', 'verified_artist', 'admin'];
    }

    function featureEnabled(flagId) {
      return get(/databases/$(database)/documents/featureFlags/$(flagId)).data.get('enabled', true) == true;
    }

    function isMaintenanceMode() {
      return get(/databases/$(database)/documents/featureFlags/maintenance_mode).data.get('enabled', false) == true;
    }

    function allowClientWrite() {
      return !isMaintenanceMode() || isAdmin();
    }


    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }


    function protectedStatFields() {
      return ['followerCount', 'followingCount', 'salesCount', 'totalRevenue', 'artworkCount'];
    }

    function isValidClientStatusChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
        || request.resource.data.status in ['draft', 'pending', 'archived'];
    }


    function isValidEmail(field) {
      return field is string && field.size() >= 3 && field.size() <= 254 && field.matches('.*@.*');
    }

    function isValidTimestamp(field) {
      return field is string && field.size() >= 10 && field.size() <= 30;
    }

    function isValidUserCreate() {
      return isValidString(request.resource.data.displayName, 1, 100)
        && isValidEmail(request.resource.data.email)
        && request.resource.data.role in ['user', 'artist']
        && request.resource.data.isVerified == false
        && request.resource.data.isEmailVerified is bool
        && request.resource.data.isPhoneVerified is bool
        && request.resource.data.isBanned == false
        && request.resource.data.get('followerCount', 0) == 0
        && request.resource.data.get('followingCount', 0) == 0
        && request.resource.data.get('artworkCount', 0) == 0
        && request.resource.data.get('salesCount', 0) == 0
        && request.resource.data.get('totalRevenue', 0) == 0
        && isValidTimestamp(request.resource.data.createdAt)
        && isValidTimestamp(request.resource.data.updatedAt);
    }

    function isValidArtworkCreate() {
      return request.resource.data.artistId == request.auth.uid
        && request.resource.data.status == 'draft'
        && isValidString(request.resource.data.title, 1, 200)
        && isValidString(request.resource.data.description, 0, 5000)
        && request.resource.data.price is number && request.resource.data.price >= 0
        && request.resource.data.currency == 'INR'
        && request.resource.data.listingType in ['fixed_price', 'auction', 'commission', 'not_for_sale']
        && isValidString(request.resource.data.category, 1, 100)
        && isValidString(request.resource.data.medium, 1, 200)
        && request.resource.data.year is int && request.resource.data.year >= 1000 && request.resource.data.year <= 2100
        && request.resource.data.viewCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.favoriteCount == 0
        && request.resource.data.images is list
        && request.resource.data.tags is list;
    }

    function isValidArtworkOwnerUpdate() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['price'])
          || (request.resource.data.price is number && request.resource.data.price >= 0))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['title'])
          || isValidString(request.resource.data.title, 1, 200));
    }

    // Any visitor may bump viewCount on published artworks (increment-only).
    function isPublishedViewCountUpdate() {
      return resource.data.status == 'published'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount is int
        && request.resource.data.viewCount == resource.data.viewCount + 1;
    }

    function isPublicArtworkRead() {
      return resource.data.status == 'published'
        || (resource.data.listingType == 'auction'
          && resource.data.status != 'draft'
          && resource.data.status != 'archived');
    }

    function isValidAuctionCreate() {
      return request.resource.data.artistId == request.auth.uid
        && isValidString(request.resource.data.artworkId, 1, 128)
        && request.resource.data.startPrice is number && request.resource.data.startPrice >= 0
        && request.resource.data.currentBid is number && request.resource.data.currentBid >= 0
        && request.resource.data.minIncrement is number && request.resource.data.minIncrement > 0
        && request.resource.data.currency == 'INR'
        && request.resource.data.type in ['timed', 'live']
        && request.resource.data.status in ['scheduled', 'live']
        && isValidTimestamp(request.resource.data.startsAt)
        && isValidTimestamp(request.resource.data.endsAt)
        && request.resource.data.totalBids == 0
        && request.resource.data.uniqueBidders == 0;
    }

    function isValidNotificationCreate() {
      return isValidString(request.resource.data.userId, 1, 128)
        && request.resource.data.type in [
          'bid_placed', 'bid_outbid', 'auction_won', 'auction_lost', 'auction_ending',
          'auction_closed_artist', 'order_placed', 'order_shipped', 'order_delivered',
          'payment_received', 'new_follower', 'new_comment', 'new_like', 'new_message',
          'new_community_message', 'new_mention',
          'artwork_approved', 'artwork_rejected', 'verification_approved',
          'verification_rejected', 'event_reminder', 'system'
        ]
        && isValidString(request.resource.data.title, 1, 200)
        && isValidString(request.resource.data.message, 1, 1000)
        && request.resource.data.isRead == false;
    }

    function isValidNotificationUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
        && request.resource.data.isRead is bool;
    }

    function isValidChatRoomCreate() {
      return request.resource.data.type in ['direct', 'group']
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participantNames is map
        && request.resource.data.participantAvatars is map
        && request.resource.data.unreadCount is map
        && isValidTimestamp(request.resource.data.createdAt)
        && isValidTimestamp(request.resource.data.updatedAt);
    }

    function isValidChatRoomUpdate() {
      return resource.data.participants is list
        && request.resource.data.participants is list
        && request.auth.uid in resource.data.participants
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastMessageAt', 'lastMessageBy', 'unreadCount', 'updatedAt']);
    }

    function isChatRoomParticipant(roomId) {
      return exists(/databases/$(database)/documents/chatRooms/$(roomId))
        && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
    }

    // Collection-group queries on `members` (e.g. subscribeToUserCommunities) require a
    // recursive wildcard rule — nested community rules alone do not apply to collection groups.
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    function isValidOrderSellerUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'trackingNumber', 'shippingProvider', 'sellerNotes', 'statusHistory', 'updatedAt'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['trackingNumber'])
          || (request.resource.data.trackingNumber is string
              && request.resource.data.trackingNumber.size() <= 100))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
          || request.resource.data.status in ['processing', 'shipped', 'delivered', 'completed']);
    }

    // ── Users ─────────────────────────────────────────────

    match /users/{userId} {
      // Anyone can read user profiles (public profiles)
      allow read: if true;

      // Users can create their own profile
      allow create: if isOwner(userId) && isValidUserCreate();

      // Users can update their own profile. They may choose between collector
      // and artist roles, but verified/admin/moderation fields stay protected.
      allow update: if (isOwner(userId) && resource.data.role == 'admin')
        || (isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(protectedStatFields())
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isVerified', 'isBanned'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
          || request.resource.data.role in ['user', 'artist']
        ))
        || (isAdmin() && !isOwner(userId));

      // Only admin can delete users
      allow delete: if isAdmin();

      // Followers subcollection (Cloud Functions only)
      match /followers/{followerId} {
        allow read: if true;
        allow write: if false;
      }

      // Following subcollection (Cloud Functions only)
      match /following/{followingId} {
        allow read: if true;
        allow write: if false;
      }

      // User notifications (Cloud Functions only)
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create: if false;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // User addresses
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Artworks ──────────────────────────────────────────

    match /artworks/{artworkId} {
      // Published artworks are public; auction-listed works visible to bidders
      allow read: if isPublicArtworkRead()
        || isOwner(resource.data.artistId)
        || isAdmin();

      // Artists can create artworks (draft only)
      allow create: if isArtist() && isValidArtworkCreate()
        && allowClientWrite()
        && featureEnabled('enable_artwork_uploads');

      // Owner can update their artworks; admin can update any; public viewCount bump
      allow update: if (isOwner(resource.data.artistId)
          && isValidClientStatusChange()
          && isValidArtworkOwnerUpdate()
          && allowClientWrite()
          && featureEnabled('enable_artwork_uploads'))
        || isAdmin()
        || isPublishedViewCountUpdate();

      // Owner can delete drafts; admin can delete any
      allow delete: if (isOwner(resource.data.artistId)
        && resource.data.status in ['draft', 'archived'])
        || isAdmin();
    }

    // ── Auctions ──────────────────────────────────────────

    match /auctions/{auctionId} {
      // Active auctions are public
      allow read: if true;

      // Artists can create auctions for their artworks
      allow create: if isArtist() && isValidAuctionCreate()
        && allowClientWrite()
        && featureEnabled('enable_auctions');

      // Only Cloud Functions should update auctions (bids, status changes)
      // Allow admin for emergency overrides
      allow update: if isAdmin();

      // Admin can cancel auctions
      allow delete: if isAdmin();

      // Nested bids collection
      match /bids/{bidId} {
        allow read: if true;
        // Bids are ONLY created via Cloud Functions
        allow create: if false;
        allow update, delete: if false;
      }
    }

    // ── Bids (collection-group + top-level) ───────────────

    // Collection-group queries: user may read only their own bids
    match /{path=**}/bids/{bidId} {
      allow read: if isAuthenticated()
        && resource.data.bidderId == request.auth.uid;
    }

    match /bids/{bidId} {
      // Owner-only read for top-level bid documents
      allow read: if isAuthenticated()
        && resource.data.bidderId == request.auth.uid;

      // Bids are ONLY created via Cloud Functions (server-side validation)
      allow create: if false;

      // No client-side bid updates
      allow update: if false;

      allow delete: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────

    match /orders/{orderId} {
      // Buyer and seller can read their orders; admin can read all
      allow read: if isOwner(resource.data.buyerId)
        || isOwner(resource.data.sellerId)
        || isAdmin();

      // Orders created only via Cloud Functions (verifyPayment)
      allow create: if false;

      // Status updates mostly via Cloud Functions
      // Seller can update shipping info; admin can update anything
      allow update: if (isOwner(resource.data.sellerId) && isValidOrderSellerUpdate())
        || isAdmin();

      allow delete: if false;
    }

    // ── Checkout Sessions (server-only) ───────────────────

    match /checkoutSessions/{sessionId} {
      allow read, write: if false;
    }

    // ── Payment Locks (server-only idempotency) ───────────

    match /paymentLocks/{lockId} {
      allow read, write: if false;
    }

    match /paymentCaptures/{captureId} {
      allow read, write: if false;
    }

    // ── Payments ──────────────────────────────────────────

    match /payments/{paymentId} {
      // Admin only — payment records are created by Cloud Functions
      allow read: if isAdmin();

      // Payments only created by Cloud Functions
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── Carts ─────────────────────────────────────────────

    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ── Favorites / Bookmarks ─────────────────────────────

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ── Collections ───────────────────────────────────────

    match /collections/{collectionId} {
      allow read: if resource.data.isPublic || isOwner(resource.data.userId);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── Posts ──────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && allowClientWrite()
        && featureEnabled('enable_social_feed');
      allow update: if isOwner(resource.data.authorId) || isModerator();
      allow delete: if isOwner(resource.data.authorId) || isModerator();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated()
          && allowClientWrite()
          && featureEnabled('enable_social_feed');
        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid;
        allow delete: if (isAuthenticated()
          && resource.data.authorId == request.auth.uid)
          || isModerator();
      }

      match /likes/{likeId} {
        allow read: if true;
        allow create: if isAuthenticated()
          && allowClientWrite()
          && featureEnabled('enable_social_feed');
        allow delete: if isAuthenticated();
      }
    }

    // ── Chat Rooms ────────────────────────────────────────

    match /chatRooms/{roomId} {
      // List queries must use array-contains request.auth.uid (see subscribeToRooms).
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChatRoomCreate();
      allow update: if isAuthenticated() && isValidChatRoomUpdate();

      match /messages/{messageId} {
        allow read: if isAuthenticated() && isChatRoomParticipant(roomId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Communities (Discord-style) ───────────────────────

    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }

      match /channels/{channelId} {
        allow read: if isAuthenticated();
        allow write: if false;

        match /messages/{messageId} {
          allow read: if isAuthenticated();
          allow write: if false;
        }
      }

      match /pinnedMessages/{pinId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }

      match /moderationLogs/{logId} {
        allow read: if false;
        allow write: if false;
      }
    }

    // ── Events ────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow create: if isArtist() || isAdmin();
      allow update: if isOwner(resource.data.organizerId) || isAdmin();
      allow delete: if isOwner(resource.data.organizerId) || isAdmin();

      match /registrations/{regId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && allowClientWrite()
          && featureEnabled('enable_social_feed');
        allow update: if isOwner(regId) || isAdmin();
        allow delete: if isOwner(regId) || isAdmin();
      }
    }

    // ── Workshops ─────────────────────────────────────────

    match /workshops/{workshopId} {
      allow read: if true;
      allow create: if isArtist() || isAdmin();
      allow update: if isOwner(resource.data.instructorId) || isAdmin();
      allow delete: if isAdmin();

      match /enrollments/{enrollId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && allowClientWrite()
          && featureEnabled('enable_social_feed');
        allow update: if isOwner(enrollId) || isAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidNotificationCreate();
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && isValidNotificationUpdate();
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // ── Artist Verifications ──────────────────────────────

    match /artistVerifications/{verifId} {
      allow read: if isOwner(resource.data.artistId) || isAdmin();
      allow create: if isArtist()
        && request.resource.data.artistId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Categories ────────────────────────────────────────

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Tags ──────────────────────────────────────────────

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Admin Logs ────────────────────────────────────────

    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── Audit Logs ────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Analytics ─────────────────────────────────────────

    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ── Feature Flags ─────────────────────────────────────

    match /featureFlags/{flagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── System Configs ────────────────────────────────────

    match /systemConfigs/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Rate Limits (Cloud Functions only) ────────────────

    match /_rateLimits/{limitId} {
      allow read, write: if false;
    }
  }
}
